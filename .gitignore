# === Per-deployment server config ===
# Written by GPUCONFIGURE.bat → gpu-configure.html admin UI.
# Each operator picks their own resource tier; host-specific.
server/resource-config.json

# === T18.12 per-machine runtime artifact ===
# autoClearStaleState() writes SHA256 of the brain-logic source files
# to this file on every boot. Compared against the prior-boot value to
# decide whether to preserve or clear state. Per-machine + per-boot
# runtime data; must not be committed. Each clone computes its own
# hash on first boot.
server/brain-code-hash.json

# === T18.37 per-machine runtime log ===
# start.bat + Savestart.bat redirect node brain-server.js stdout/stderr
# to server/server.log so operators can tail heartbeat + brain info even
# if the launcher terminal goes invisible (Windows Terminal rendering
# glitches). Per-boot runtime data; must not be committed.
server/server.log

